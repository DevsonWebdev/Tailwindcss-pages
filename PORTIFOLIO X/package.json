{
  "name": "portifolio",
  "version": "1.0.0",
  "description": "A modern portfolio website for a web developer showcasing projects, skills, and contact information. Built with HTML, CSS, JavaScript, and optimized for performance and responsiveness. Visitors can explore the developer's work, learn about their background, and get in touch for collaborations or job opportunities.",
  "scripts": {
    "watch-styles": "npx tailwindcss -i ./src/tailwind/input.css -o ./src/styles/styles.css --watch",
    "build-styles": "npx tailwindcss -i ./src/tailwind/input.css -o ./src/styles/styles.css --minify",
    "start": "parcel src/index.html",
    "build": " parcel build src/index.html --dist-dir dist",
    "buildprod": "npm run build-styles && npm run build"
  },
  "keywords": [
    "portfolio",
    "web developer",
    "projects",
    "skills",
    "contact information",
    "HTML",
    "CSS",
    "JavaScript",
    "responsive design",
    "performance optimization"
  ],
  "author": "Devson Webdve",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@parcel/transformer-webmanifest": "^2.16.4",
    "autoprefixer": "^10.4.27",
    "parcel": "^2.16.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.19",
    "aos": "^2.3.4",
    "bootstrap-icons": "^1.13.1",
    "glightbox": "^3.3.1",
    "jquery": "^4.0.0",
    "scrollreveal": "^4.0.9",
    "swiper": "^12.1.2"
  }
}
